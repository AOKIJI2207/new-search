{
  "name": "news-search",
  "private": true,
  "version": "1.0.0",
  "description": "Static news search UI with Vercel serverless RSS endpoints.",
  "type": "module",
  "scripts": {
    "dev": "vercel dev",
    "start": "vercel dev",
    "check": "node --check server/country-store.js && node --check scripts/update-country-data.js && node --check scripts/validate-dataset.js",
    "test:countries-index": "node scripts/check-countries-index.mjs",
    "generate:country-dataset": "node scripts/generate-country-profiles.mjs",
    "validate:country-dataset": "node scripts/validate-country-dataset.mjs",
    "update-data": "node scripts/update-country-data.js",
    "validate-data": "node scripts/validate-dataset.js"
  },
  "dependencies": {
    "rss-parser": "^3.13.0"
  },
  "engines": {
    "node": ">=18"
  }
}
